{"messages": [{"version": "v0.9.1", "createSurface": {"surfaceId": "kalmio-chat", "catalogId": "https://kalmio.app/a2ui/catalogs/ev-assistant/v1/catalog.json", "sendDataModel": true}}, {"version": "v0.9.1", "updateComponents": {"surfaceId": "kalmio-chat", "components": [{"text": "Cu\u00e9ntame qu\u00e9 necesitas: una ruta completa, cargar cerca de donde est\u00e1s, o una parada de carga cerca de un hotel o destino. Si falta un dato cr\u00edtico, te lo pedir\u00e9.", "id": "assistant-initial", "component": "AssistantMessage", "version": 1}, {"chips": ["Necesito cargar ya", "Ruta con parada segura", "Parada cerca del hotel", "Priorizar servicios"], "id": "preference-starters", "component": "PreferenceChips", "version": 1}, {"text": "Voy de Sevilla a Granada, \u00bfme da para llegar sin cargar?", "id": "user-79360a51f1", "component": "UserMessage", "version": 1}, {"text": "Para saber si llegas sin cargar necesito algunos datos de tu coche: \u00bfqu\u00e9 modelo tienes, cu\u00e1nta bater\u00eda te queda y cu\u00e1l es tu consumo medio?", "id": "msg1", "component": "AssistantMessage", "version": 1}]}}, {"version": "v0.9.1", "updateDataModel": {"surfaceId": "kalmio-chat", "path": "/", "value": {"conversation": {"surfaceId": "kalmio-chat", "componentOrder": [{"id": "assistant-initial", "component": "AssistantMessage"}, {"id": "preference-starters", "component": "PreferenceChips"}, {"id": "user-79360a51f1", "component": "UserMessage"}, {"id": "msg1", "component": "AssistantMessage"}]}, "facts": {"locations": [], "routes": [], "stops": [], "risks": []}}}}]}