{"messages": [{"version": "v0.9.1", "createSurface": {"surfaceId": "kalmio-chat", "catalogId": "https://kalmio.app/a2ui/catalogs/ev-assistant/v1/catalog.json", "sendDataModel": true}}, {"version": "v0.9.1", "updateComponents": {"surfaceId": "kalmio-chat", "components": [{"text": "Cu\u00e9ntame qu\u00e9 necesitas: una ruta completa, cargar cerca de donde est\u00e1s, o una parada de carga cerca de un hotel o destino. Si falta un dato cr\u00edtico, te lo pedir\u00e9.", "id": "assistant-initial", "component": "AssistantMessage", "version": 1}, {"chips": ["Necesito cargar ya", "Ruta con parada segura", "Parada cerca del hotel", "Priorizar servicios"], "id": "preference-starters", "component": "PreferenceChips", "version": 1}, {"text": "Evita cargadores caros si hay alternativas razonables", "id": "user-cccc62a510", "component": "UserMessage", "version": 1}, {"text": "Entendido, evitar\u00e9 cargadores caros siempre que haya alternativas razonables. Lo tendr\u00e9 en cuenta para las pr\u00f3ximas b\u00fasquedas y rutas.", "id": "pref_cheap", "component": "AssistantMessage", "version": 1}]}}, {"version": "v0.9.1", "updateDataModel": {"surfaceId": "kalmio-chat", "path": "/", "value": {"conversation": {"surfaceId": "kalmio-chat", "componentOrder": [{"id": "assistant-initial", "component": "AssistantMessage"}, {"id": "preference-starters", "component": "PreferenceChips"}, {"id": "user-cccc62a510", "component": "UserMessage"}, {"id": "pref_cheap", "component": "AssistantMessage"}]}, "facts": {"locations": [], "routes": [], "stops": [], "risks": []}}}}]}