{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kalmio.app/a2ui/catalogs/ev-assistant/v1/catalog.json",
  "catalogId": "https://kalmio.app/a2ui/catalogs/ev-assistant/v1/catalog.json",
  "version": "v1.0",
  "description": "Kalmio EV assistant A2UI catalog. Agents may use only these domain components and registered functions. Charging recommendations are station-first and backed by traceable station, EVSE and connector data.",
  "components": {
    "AssistantMessage": {
      "type": "object",
      "properties": {
        "text": { "type": "string", "minLength": 1 }
      },
      "required": ["text"],
      "additionalProperties": false
    },
    "UserMessage": {
      "type": "object",
      "properties": {
        "text": { "type": "string", "minLength": 1 }
      },
      "required": ["text"],
      "additionalProperties": false
    },
    "TripSummaryCard": {
      "allOf": [
        { "$ref": "#/$defs/decisionProps" },
        {
          "type": "object",
          "properties": {
            "origin": { "$ref": "#/$defs/displayValue" },
            "destination": { "$ref": "#/$defs/displayValue" },
            "battery": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "arrivalReservePercent": { "type": ["number", "null"], "minimum": 0, "maximum": 100 }
          },
          "additionalProperties": true
        }
      ]
    },
    "RouteSummaryCard": {
      "allOf": [
        { "$ref": "#/$defs/decisionProps" },
        {
          "type": "object",
          "properties": {
            "distanceKm": { "type": ["number", "null"], "minimum": 0 },
            "durationMin": { "type": ["number", "null"], "minimum": 0 },
            "energyKwh": { "type": ["number", "null"], "minimum": 0 },
            "arrivalBattery": { "type": ["number", "null"], "minimum": 0, "maximum": 100 }
          },
          "additionalProperties": true
        }
      ]
    },
    "StationPreviewCard": {
      "allOf": [
        { "$ref": "#/$defs/stationProps" },
        { "$ref": "#/$defs/decisionProps" }
      ]
    },
    "StationDetailCard": {
      "allOf": [
        { "$ref": "#/$defs/stationProps" },
        { "$ref": "#/$defs/decisionProps" }
      ]
    },
    "StationList": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "stations": {
          "type": "array",
          "maxItems": 5,
          "items": { "$ref": "#/$defs/stationProps" }
        },
        "uncertainty": { "$ref": "#/$defs/uncertainty" }
      },
      "required": ["stations"],
      "additionalProperties": false
    },
    "RiskExplanationCard": {
      "type": "object",
      "properties": {
        "level": { "enum": ["info", "bajo", "baja", "medio", "media", "alto", "alta", "high", "medium"] },
        "text": { "type": "string", "minLength": 1 },
        "uncertainty": { "$ref": "#/$defs/uncertainty" },
        "primaryAction": { "$ref": "#/$defs/action" }
      },
      "required": ["text"],
      "additionalProperties": false
    },
    "CostComparisonCard": {
      "allOf": [
        { "$ref": "#/$defs/decisionProps" },
        {
          "type": "object",
          "properties": {
            "best": { "$ref": "#/$defs/displayValue" },
            "pricePerKwhEur": { "type": ["number", "null"], "minimum": 0 },
            "comparedWith": { "$ref": "#/$defs/displayValue" },
            "comparedWithPricePerKwhEur": { "type": ["number", "null"], "minimum": 0 },
            "savingPerKwhEur": { "type": ["number", "null"] },
            "currency": { "type": "string" },
            "priceIsEstimated": { "type": ["boolean", "null"] },
            "estimatedCostEur": { "type": ["number", "null"], "minimum": 0 },
            "savingEur": { "type": ["number", "null"] }
          },
          "additionalProperties": true
        }
      ]
    },
    "MapPreviewCard": {
      "type": "object",
      "properties": {
        "routeId": { "type": "string" },
        "origin": { "$ref": "#/$defs/mapPoint" },
        "destination": { "$ref": "#/$defs/mapPoint" },
        "primaryStation": { "$ref": "#/$defs/stationProps" },
        "stations": {
          "type": "array",
          "maxItems": 8,
          "items": { "$ref": "#/$defs/stationProps" }
        },
        "routeGeometry": { "$ref": "#/$defs/lineStringGeometry" },
        "corridorRadiusKm": { "type": ["number", "null"], "minimum": 0 },
        "geometryPrecision": { "enum": ["provider", "schematic", "unknown"] },
        "source": { "type": "string" }
      },
      "additionalProperties": false
    },
    "ActionButtons": {
      "type": "object",
      "properties": {
        "actions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": { "$ref": "#/$defs/action" }
        }
      },
      "required": ["actions"],
      "additionalProperties": false
    },
    "ClarifyingQuestionCard": {
      "type": "object",
      "properties": {
        "question": { "type": "string", "minLength": 1 },
        "fields": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "maxItems": 6
        },
        "primaryAction": { "$ref": "#/$defs/action" }
      },
      "required": ["question"],
      "additionalProperties": false
    },
    "PositionRequestCard": {
      "type": "object",
      "properties": {
        "reason": { "enum": ["urgent_charge", "nearby_chargers", "route_origin"] },
        "title": { "type": "string", "minLength": 1 },
        "body": { "type": "string", "minLength": 1 },
        "precision": { "enum": ["exact", "approximate"] },
        "manualFields": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "maxItems": 5
        }
      },
      "required": ["title", "body"],
      "additionalProperties": false
    },
    "PlaceDetailCard": {
      "type": "object",
      "properties": {
        "label": { "$ref": "#/$defs/displayValue" },
        "lat": { "type": ["number", "null"], "minimum": -90, "maximum": 90 },
        "lon": { "type": ["number", "null"], "minimum": -180, "maximum": 180 },
        "precision": { "enum": ["exact", "approximate"] },
        "context": { "type": "string" },
        "needsConfirmation": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "PreferenceChips": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "chips": {
          "type": "array",
          "minItems": 1,
          "maxItems": 6,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "required": ["chips"],
      "additionalProperties": false
    },
    "ErrorFallbackCard": {
      "type": "object",
      "properties": {
        "originalType": { "type": "string" },
        "message": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "functions": [
    {
      "name": "openUrl",
      "description": "Open a safe http(s) URL in a new browser context.",
      "parameters": {
        "type": "object",
        "properties": {
          "url": { "type": "string", "pattern": "^https?://" }
        },
        "required": ["url"],
        "additionalProperties": false
      }
    }
  ],
  "theme": {
    "type": "object",
    "description": "Renderer-owned Kalmio theme values. Agents should use semantic props rather than visual styling."
  },
  "$defs": {
    "displayValue": {
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" },
        {
          "type": "object",
          "properties": {
            "label": { "type": "string" },
            "name": { "type": "string" },
            "title": { "type": "string" },
            "text": { "type": "string" },
            "value": {}
          },
          "additionalProperties": true
        }
      ]
    },
    "mapPoint": {
      "anyOf": [
        { "$ref": "#/$defs/displayValue" },
        {
          "type": "object",
          "properties": {
            "label": { "type": "string" },
            "name": { "type": "string" },
            "title": { "type": "string" },
            "text": { "type": "string" },
            "lat": { "type": ["number", "null"], "minimum": -90, "maximum": 90 },
            "lon": { "type": ["number", "null"], "minimum": -180, "maximum": 180 }
          },
          "additionalProperties": true
        }
      ]
    },
    "lineStringGeometry": {
      "type": "object",
      "properties": {
        "type": { "const": "LineString" },
        "coordinates": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2000,
          "items": {
            "type": "array",
            "prefixItems": [
              { "type": "number", "minimum": -180, "maximum": 180 },
              { "type": "number", "minimum": -90, "maximum": 90 }
            ],
            "items": false,
            "minItems": 2,
            "maxItems": 2
          }
        }
      },
      "required": ["type", "coordinates"],
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "value": { "type": ["string", "number", "boolean", "null"] },
        "unit": { "type": "string" },
        "status": { "enum": ["known", "estimated", "unknown"] },
        "sourcePath": { "type": "string" }
      },
      "required": ["label", "value"],
      "additionalProperties": false
    },
    "uncertainty": {
      "type": "object",
      "properties": {
        "level": { "enum": ["info", "medium", "high"] },
        "text": { "type": "string", "minLength": 1 },
        "source": { "type": "string" },
        "freshness": { "type": "string" }
      },
      "required": ["level", "text"],
      "additionalProperties": false
    },
    "event": {
      "type": "object",
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "context": { "type": "object", "additionalProperties": true }
      },
      "required": ["name"],
      "additionalProperties": false
    },
    "functionCall": {
      "type": "object",
      "properties": {
        "call": { "const": "openUrl" },
        "args": {
          "type": "object",
          "properties": {
            "url": { "type": "string", "pattern": "^https?://" }
          },
          "required": ["url"],
          "additionalProperties": false
        }
      },
      "required": ["call", "args"],
      "additionalProperties": false
    },
    "action": {
      "type": "object",
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "priority": { "enum": ["primary", "secondary"] },
        "disabled": { "type": "boolean" },
        "reason": { "type": "string" },
        "event": { "$ref": "#/$defs/event" },
        "functionCall": { "$ref": "#/$defs/functionCall" }
      },
      "required": ["label"],
      "oneOf": [
        { "required": ["event"] },
        { "required": ["functionCall"] },
        { "required": ["disabled"] }
      ],
      "additionalProperties": false
    },
    "decisionProps": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "takeaway": { "type": "string" },
        "why": { "type": "string" },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence" },
          "maxItems": 6
        },
        "uncertainty": { "$ref": "#/$defs/uncertainty" },
        "primaryAction": { "$ref": "#/$defs/action" }
      },
      "additionalProperties": true
    },
    "stationProps": {
      "type": "object",
      "properties": {
        "stationName": { "$ref": "#/$defs/displayValue" },
        "name": { "$ref": "#/$defs/displayValue" },
        "address": { "$ref": "#/$defs/displayValue" },
        "connectorTypes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "maxItems": 8
        },
        "availableEvses": { "type": ["number", "null"], "minimum": 0 },
        "totalEvses": { "type": ["number", "null"], "minimum": 0 },
        "amenities": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "maxItems": 12
        },
        "powerKw": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Maximum charging power registered for the station, in kW. Not live or guaranteed delivered power."
        },
        "pricePerKwhEur": { "type": ["number", "null"], "minimum": 0 },
        "currency": { "type": "string" },
        "priceIsEstimated": { "type": ["boolean", "null"] },
        "distanceKm": { "type": ["number", "null"], "minimum": 0 },
        "detourMin": { "type": ["number", "null"] },
        "confidence": { "$ref": "#/$defs/displayValue" },
        "lat": { "type": ["number", "null"], "minimum": -90, "maximum": 90 },
        "lon": { "type": ["number", "null"], "minimum": -180, "maximum": 180 }
      },
      "additionalProperties": true
    },
    "listItem": {
      "type": "object",
      "properties": {
        "name": { "$ref": "#/$defs/displayValue" },
        "deltaMin": { "type": ["number", "null"] },
        "powerKw": {
          "type": ["number", "null"],
          "description": "Maximum charging power registered for the station, in kW. Not live or guaranteed delivered power."
        },
        "distanceKm": { "type": ["number", "null"] },
        "takeaway": { "type": "string" }
      },
      "additionalProperties": true
    }
  }
}
