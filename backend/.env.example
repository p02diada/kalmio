KALMIO_ENV=development
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=dev-only-change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_TRUST_X_FORWARDED_PROTO=false
KALMIO_DB_ENGINE=sqlite
KALMIO_ROUTING_PROVIDER=osrm
KALMIO_OSRM_BASE_URL=https://router.project-osrm.org
KALMIO_OSRM_TIMEOUT_SECONDS=5
KALMIO_ROUTING_REQUEST_RETRIES=1
KALMIO_ROUTING_READINESS_CHECK=false
KALMIO_ROUTE_CONVERSATION_THROTTLE_LIMIT=30
KALMIO_ROUTE_CONVERSATION_THROTTLE_WINDOW_SECONDS=120
KALMIO_CONVERSATION_AGENT_MODE=deepseek
KALMIO_DEEPSEEK_API_KEY=
KALMIO_DEEPSEEK_BASE_URL=https://api.deepseek.com
KALMIO_DEEPSEEK_MODEL=deepseek-v4-flash
KALMIO_DEEPSEEK_TIMEOUT_SECONDS=30
KALMIO_DEEPSEEK_MAX_TOOL_CALLS=3
KALMIO_DEEPSEEK_MAX_TOKENS=1800
KALMIO_DEEPSEEK_TEMPERATURE=0
KALMIO_DEEPSEEK_USE_NATIVE_TOOLS=true
KALMIO_DEEPSEEK_THINKING=false
KALMIO_DEEPSEEK_REASONING_EFFORT=high
KALMIO_DEEPSEEK_PRICE_INPUT_CACHE_HIT_PER_MILLION_USD=0.0028
KALMIO_DEEPSEEK_PRICE_INPUT_CACHE_MISS_PER_MILLION_USD=0.14
KALMIO_DEEPSEEK_PRICE_OUTPUT_PER_MILLION_USD=0.28
KALMIO_AGENT_TRACE_ENABLED=true
KALMIO_AGENT_TRACE_INCLUDE_PAYLOADS=false
KALMIO_AGENT_TRACE_FILE=.tmp/agent-traces.jsonl
KALMIO_AGENT_TRACE_MAX_PAYLOAD_CHARS=12000
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
POSTGRES_DB=kalmio
POSTGRES_USER=kalmio
POSTGRES_PASSWORD=kalmio
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
