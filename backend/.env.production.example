KALMIO_ENV=production
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-from-your-secret-manager
DJANGO_ALLOWED_HOSTS=api.kalmio.example
CORS_ALLOWED_ORIGINS=https://app.kalmio.example
CSRF_TRUSTED_ORIGINS=https://app.kalmio.example

KALMIO_DB_ENGINE=postgis
POSTGRES_DB=kalmio
POSTGRES_USER=kalmio
POSTGRES_PASSWORD=replace-with-a-strong-database-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Use require for managed/external PostGIS. The bundled production compose
# uses an internal Docker network PostGIS service, which does not expose SSL.
POSTGRES_SSLMODE=disable

KALMIO_GEOCODING_PROVIDER=mapbox
KALMIO_MAPBOX_ACCESS_TOKEN=replace-with-mapbox-access-token
KALMIO_MAPBOX_GEOCODING_BASE_URL=https://api.mapbox.com
KALMIO_MAPBOX_SEARCH_API=auto
KALMIO_GEOCODING_COUNTRY=ES
KALMIO_GEOCODING_LANGUAGE=es
KALMIO_GEOCODING_TIMEOUT_SECONDS=4
KALMIO_GEOCODING_REQUEST_RETRIES=1
KALMIO_GEOCODING_LIMIT=5
KALMIO_ROUTING_PROVIDER=osrm
KALMIO_OSRM_BASE_URL=https://routes.kalmio.example
KALMIO_OSRM_TIMEOUT_SECONDS=5
KALMIO_ROUTING_REQUEST_RETRIES=1
KALMIO_ROUTING_READINESS_CHECK=true
ITERNIO_API_KEY=replace-with-iternio-api-key-issued-for-kalmio
KALMIO_ROUTE_CONVERSATION_THROTTLE_LIMIT=30
KALMIO_ROUTE_CONVERSATION_THROTTLE_WINDOW_SECONDS=120
KALMIO_CONVERSATION_AGENT_MODE=deepseek
KALMIO_CONVERSATION_AGENT_RUNTIME=pydantic_ai
KALMIO_DEEPSEEK_API_KEY=replace-with-deepseek-api-key
KALMIO_DEEPSEEK_BASE_URL=https://api.deepseek.com
KALMIO_DEEPSEEK_MODEL=deepseek-v4-pro
KALMIO_DEEPSEEK_TIMEOUT_SECONDS=30
KALMIO_DEEPSEEK_MAX_TOOL_CALLS=3
KALMIO_DEEPSEEK_MAX_TOKENS=1800
KALMIO_DEEPSEEK_TEMPERATURE=0
KALMIO_DEEPSEEK_USE_NATIVE_TOOLS=true
KALMIO_DEEPSEEK_THINKING=false
KALMIO_DEEPSEEK_REASONING_EFFORT=high

KALMIO_ENABLE_ADMIN=false
KALMIO_ENABLE_API_DOCS=false
KALMIO_AUTH_THROTTLE_LIMIT=5
KALMIO_AUTH_THROTTLE_WINDOW_SECONDS=900
KALMIO_LOGFIRE_ENABLED=false
KALMIO_LOGFIRE_SERVICE_NAME=kalmio-backend
LOGFIRE_TOKEN=replace-with-logfire-write-token
KALMIO_LOGFIRE_SEND_TO_LOGFIRE=if-token-present
KALMIO_LOGFIRE_INSTRUMENT_DJANGO=true
KALMIO_LOGFIRE_INSTRUMENT_HTTPX=true
KALMIO_LOG_LEVEL=INFO
